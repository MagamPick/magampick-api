APP_IMAGE=magampick-api:latest
SPRING_PROFILES_ACTIVE=prod

POSTGRES_DB=magampick
POSTGRES_USER=magampick
POSTGRES_PASSWORD=change-me

# SOLAPI (SMS 본인인증) — test 외 모든 프로파일에서 실발송에 필요. 발신번호는 SOLAPI 콘솔에 등록한 번호(숫자만)
SOLAPI_API_KEY=change-me
SOLAPI_API_SECRET=change-me
SOLAPI_SENDER_NUMBER=01000000000

# 초기 admin 시드 — 앱 시작 시 admin 이 없으면 이 계정을 자동 생성. 미설정 시 건너뜀.
# 비밀번호 정책: 8자 이상, 영문+숫자+특수문자 각 1개 이상
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-Admin1!
